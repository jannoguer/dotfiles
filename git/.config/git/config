[core]
    excludesfile = ~/.config/git/.gitignore
    hooksPath = ~/.config/git/hooks
    autocrlf = input
    eol = lf
    editor = vim
[init]
	defaultbranch = main
[user]
	email = jannoguer@gmail.com
	name = jannoguer
[alias]
    ; Shortcut for `git status` command
    s = status

    ; Shortcut for git log
    l = log --oneline -n 5

    ; Creates a commit with no file changes
    empty-commit = commit --allow-empty

    ; Commits with a blank message
    empty-commit-message = commit --allow-empty-message -m \"\"

    ; Removes the last commit and keeps changes staged
    undo = reset --soft HEAD~1

    ; Applies and removes the latest stash
    unstash = stash pop

    ; Lists all local and remote branches with commit details
    branches = !git --no-pager branch -avv

    ; Lists all custom Git aliases you have configured
    aliases = !git config --global --list | grep alias | cut -d'.' -f2 | cut -d'=' -f1

    ; Stages everything and commits with the message 'wip'
    wip = !git add -A && git commit -m 'wip'

    ; Undoes the last commit if its message is exactly 'wip', keeping changes unstaged
    unwip = "!f() { \
        msg=$(git log -1 --pretty=%B); \
        [ \"$msg\" = 'wip' ] || { echo \"unwip: last commit message is not 'wip' (got: '$msg')\" >&2; return 1; }; \
        git reset HEAD~1; \
    }; f"

    ; Tags a branch as archived, then force-deletes it locally
    tuck = "!f() { \
        [ -n \"$1\" ] || { echo 'usage: git tuck <branch>' >&2; return 1; }; \
        git show-ref --verify --quiet \"refs/heads/$1\" || { echo \"tuck: branch '$1' not found\" >&2; return 1; }; \
        [ \"$(git symbolic-ref --quiet --short HEAD)\" != \"$1\" ] || { echo 'tuck: cannot tuck the current branch' >&2; return 1; }; \
        git tag \"archive/$1\" \"$1\" && git branch -D \"$1\"; \
    }; f"

    ; Restores an archived branch from its tag and checks it out
    untuck = "!f() { \
        [ -n \"$1\" ] || { echo 'usage: git untuck <branch>' >&2; return 1; }; \
        git show-ref --verify --quiet \"refs/tags/archive/$1\" || { echo \"untuck: tag 'archive/$1' not found\" >&2; return 1; }; \
        git checkout -b \"$1\" \"archive/$1\"; \
    }; f"

    ; Writes a diff of all changes (staged + unstaged vs HEAD) to a temp file and prints its path
    diffdump = "!f() { \
        [ $# -eq 0 ] || { echo 'usage: git diffdump' >&2; return 1; }; \
        tmp=$(mktemp -t git-XXXXXXX.diff) || return 1; \
        git diff HEAD > \"$tmp\"; \
        echo \"$tmp\"; \
    }; f"

    ; Prints my personal author signature
    made-by = "!echo 'Aliases by jannoguer. Keep it sharp.'"
[commit]
	template = ~/.config/git/.gitmessage
[push]
	autoSetupRemote = true